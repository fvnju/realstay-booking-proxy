# Monolith API credentials for syncing bookings
# These credentials are used to sync new bookings to the existing monolith backend
MONOLITH_EMAIL=your-email@example.com
MONOLITH_PASSWORD=your-password

# For production deployment with Cloudflare Workers, set these as secrets:
# wrangler secret put MONOLITH_EMAIL
# wrangler secret put MONOLITH_PASSWORD
