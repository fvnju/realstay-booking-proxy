{
  "name": "realstay-bookings",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply realstay-bookings-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply realstay-bookings-db --remote",
    "db:list": "wrangler d1 migrations list realstay-bookings-db",
    "db:push:local": "drizzle-kit push --config=drizzle.config.local.ts",
    "db:studio:local": "drizzle-kit studio --config=drizzle.config.local.ts",
    "init-db": "tsx scripts/init-local-db.ts",
    "migrate": "tsx scripts/migrate-bookings.ts",
    "export": "tsx scripts/export-to-sql.ts"
  },
  "dependencies": {
    "@cloudflare/workers-types": "^4.20251008.0",
    "@hono/zod-validator": "^0.4.1",
    "better-sqlite3": "^12.4.1",
    "drizzle-orm": "^0.38.2",
    "hono": "^4.9.10",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.7.0",
    "@types/uuid": "^10.0.0",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.20.6",
    "typescript": "^5.7.2",
    "wrangler": "4.42.2"
  }
}
